    "@workos-inc/authkit-react-router": "^0.10.0",
    "drizzle-orm": "^0.40.0",
    "isbot": "^5.1.27",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.5.0",
    "resend": "^6.9.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "@react-router/dev": "^7.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.21.0",
